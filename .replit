modules = ["nodejs-20", "web", "bash", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_log_in_with_replit:2.0.0"]

[nix]
channel = "stable-25_05"
packages = ["psmisc"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Backend API"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "API_PORT=8000 pnpm dev:api"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm dev:web"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "artifacts/mockup-sandbox"
isCanvasWorkflow = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm run dev"
cwd = "./artifacts/mockup-sandbox"
waitForPort = 23636
ensurePreviewReachable = "/"
router = "path"

[workflows.workflow.tasks.env]
PORT = "23636"
BASE_PATH = "/__mockup/"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 23636
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "API_PORT=8000 pnpm --filter @formai/api start & pnpm --filter @formai/web preview --host 0.0.0.0 --port 5000"]
build = ["bash", "-c", "pnpm -r build"]

[userenv]

[userenv.shared]
NODE_ENV = "development"
STORAGE_PROVIDER = "replit"

[userenv.production]
WEB_ORIGIN = "https://sproutformsai.replit.app"

[userenv.development]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[objectStorage]
defaultBucketID = "replit-objstore-74ec84cf-31b8-4609-9dfe-ddde44a2d841"
