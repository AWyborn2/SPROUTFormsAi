    "@supabase/supabase-js": "^2.110.6",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.38.4",
    "express": "^4.21.2",
    "ipaddr.js": "^2.4.0",
    "memoizee": "^0.4.17",
    "openid-client": "^6.8.4",
    "pdf-lib": "^1.17.1",
    "resend": "^6.17.2",
    "zod": "^3.24.1"
