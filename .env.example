# ─────────────────────────────────────────────────────────────
# FormAI Enterprise — environment template
# Copy to .env and fill in. NEVER commit real secrets.
# Mirrors apps/api/src/env.ts — anything not validated there is not read.
# ─────────────────────────────────────────────────────────────

# --- Database (any standard Postgres) ---
# Production targets the Supabase connection pooler URL. In dev, this can
# also point at Replit's built-in Postgres (or any other standard Postgres
# instance) — createDb() and drizzle.config.ts are provider-agnostic.
# Unset is tolerated: the API boots and every DB-backed route answers 503.
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# --- Authentication ---
# Replit Auth. No secrets: apps/api/src/auth/replit-auth.ts reads the
# X-Replit-User-* headers injected by the Replit proxy, so sign-in only works
# when the app is served through Replit. SESSION_SECRET below seals our own
# session cookie and is the only auth-related value to set.

# --- PDF storage backend ---
# 'replit' (default) uses Replit Object Storage — nothing to configure here;
# REPLIT_DEFAULT_BUCKET_URL and its sidecar credentials are injected
# automatically by the Replit platform when deployed there, never set by
# hand. Switch to 'supabase' once SUPABASE_URL/SUPABASE_SERVICE_ROLE_KEY
# below are filled in.
STORAGE_PROVIDER=replit

# --- Supabase (data + object storage only; NOT Supabase Auth) ---
# Only used when STORAGE_PROVIDER=supabase.
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Account deletion clears an org's PDFs by prefix inside this bucket, so a
# wrong name here means orphaned files rather than a loud failure.
SUPABASE_STORAGE_BUCKET_PDFS=pdfs

# --- Claude API (PDF extraction, server-side only) ---
# Unset means AcroForm PDFs still import (deterministic pdf-lib read) but
# flat/scanned ones fail with a 422 the import wizard surfaces.
ANTHROPIC_API_KEY=
ANTHROPIC_EXTRACTION_MODEL=claude-sonnet-5

# --- Resend (team invite emails) ---
# Unset means invites still persist and the UI reports emailSent: false —
# never an error. The sender must be verified in Resend for real delivery;
# the default below is Resend's shared onboarding sender, which is not.
RESEND_API_KEY=
RESEND_FROM_EMAIL=FormAI <onboarding@resend.dev>

# --- Stripe (subscription billing — not live yet) ---
STRIPE_SECRET_KEY=

# --- App ---
API_PORT=8787
WEB_ORIGIN=http://localhost:5000
# Seals the session cookie. Any non-empty value in dev; the API refuses to
# boot in production while this is left at its insecure default.
SESSION_SECRET=
